( MiscType:Misc { howpub STRING , loc INTEGER , class INTEGER , miscid INTEGER , vol INTEGER , month INTEGER , annote INTEGER , num INTEGER , note INTEGER , pages INTEGER , confloc INTEGER , year INTEGER , title STRING } ),
( ManualType:Manual { month INTEGER , loc INTEGER , class INTEGER , year INTEGER , num INTEGER , note INTEGER , pages INTEGER , manid INTEGER , title STRING , annote INTEGER , vol INTEGER , org STRING } ),
