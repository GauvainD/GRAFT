( tArticleType:TArticle { month INTEGER , articleid STRING , title STRING , vol INTEGER , pages INTEGER , fullxxxrefs STRING , preliminary STRING , xxxrefs STRING , remarks STRING , num INTEGER , refkey STRING , note STRING , year INTEGER , abstract STRING , oldkey STRING , refs STRING } ),
